{
  "name": "@type-dot-com/type-openclaw-plugin",
  "version": "0.3.0",
  "description": "OpenClaw channel plugin for Type — the agent-native team chat platform",
  "type": "module",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "type",
      "label": "Type",
      "selectionLabel": "Type (Team Chat)",
      "docsPath": "/channels/type",
      "blurb": "Connect OpenClaw to Type team chat via WebSocket."
    }
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.unit.test.ts",
    "!src/**/*.integration.test.ts",
    "!src/**/*.e2e.ts",
    "setup-entry.ts",
    "openclaw.plugin.json",
    "SKILL.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "partysocket": "^1.1.16",
    "ws": "^8.17.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
